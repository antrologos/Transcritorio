# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local virtual environments
.venv/
venv/
env/
.venv-transcricao/
transcricao-venv/

# Local editor state
.vscode/
.idea/
.github_publish/

# Runtime/build outputs
runtime/
build/
dist/
*.msi
*.dmg
*.pkg
*.AppImage
*.exe

# Build-time staging (downloaded by build.ps1)
packaging/vendor/

# Local model/download caches
models/
.cache/
huggingface/

